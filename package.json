{
  "name": "Bookstore",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "impl": "@cap-js/sqlite",
        "credentials": {
          "url": "db.sqlite"
        }
      },
      "auth": {
        "kind": "mocked",
        "users": {
          "rams": {
            "password": "1234",
            "roles": [
              "admin"
            ]
          },
          "rosy": {
            "password": "4321",
            "roles": [
              "user-that-can-call-actions"
            ]
          }
        }
      }
    }
  },
  "dependencies": {
    "@cap-js/attachments": "^3.8.0",
    "@sap/cds": "^9",
    "@sap/cds-common-content": "^3.1.0",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-typer": ">=0.1",
    "@cap-js/sqlite": "^2",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-booksstore-listview": "cds watch --open booksstorelistview/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-author-listview": "cds watch --open authorlistview/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/booksstore-listview",
    "app/author-listview"
  ],
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  }
}